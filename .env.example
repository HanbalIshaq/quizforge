SECRET_KEY=change-me-to-a-random-string
HOST=0.0.0.0
PORT=5000

# --- Database ---
# Leave DATABASE_URL empty for local SQLite (good for quick dev / demos).
# Set DATABASE_URL to a postgres:// or postgresql:// connection string for production.
# Examples (all work — switch hosts by changing this one line):
#   Neon:    postgresql://USER:PASS@ep-xxxx.aws.neon.tech/dbname?sslmode=require
#   Render:  postgresql://USER:PASS@dpg-xxxx-a.oregon-postgres.render.com/dbname
#   AWS RDS: postgresql://USER:PASS@my-db.xxxx.us-east-1.rds.amazonaws.com:5432/dbname
#   Local:   postgresql://USER:PASS@localhost:5432/quizforge
DATABASE_URL=
DATABASE_PATH=quizforge.db
